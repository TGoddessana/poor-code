Screen {
    background: $surface;
    color: $text;
    padding: 1 2;
}

.banner {
    color: $accent;
    text-style: bold;
    width: auto;
    height: auto;
    margin-bottom: 1;
}

.cwd {
    color: $text-muted;
    margin-bottom: 1;
}

PromptBox {
    dock: bottom;
    height: auto;
    border: round $accent;
    margin: 1 0;
    padding: 0 1;
}

PromptBox Input {
    background: transparent;
    border: none;
    padding: 0;
    height: 1;
}

#slash-suggest {
    max-height: 10;
    background: $surface;
    display: none;
    margin-bottom: 0;
}

#chat-log {
    height: 1fr;
    margin-top: 1;
}

#chat-scroll {
    height: 100%;
}

.user-msg {
    color: $accent;
    margin-bottom: 1;
}

.assistant-msg {
    color: $text;
    margin-bottom: 1;
}

.tool-running { color: $warning; }
.tool-done    { color: $success; }
.tool-failed  { color: $error; }

.tool-summary {
    color: $text-muted;
}

.tool-detail {
    color: $text-muted;
    margin: 0 0 0 4;
    padding-left: 2;
}

.turn-error {
    color: $error;
}

LoginScreen {
    align: center middle;
}

#login-box {
    width: 60;
    height: auto;
    padding: 1 2;
    border: round $accent;
    background: $surface;
}

.login-title {
    text-style: bold;
    color: $accent;
    margin-bottom: 1;
}

.login-label {
    color: $text-muted;
    margin-top: 1;
}

#login-buttons {
    height: auto;
    margin-top: 1;
    align-horizontal: right;
}

#login-buttons Button {
    margin-left: 1;
}

ThinkingMascot {
    dock: bottom;
    height: 1;
    color: $text-muted;
    margin: 0 1;
}
